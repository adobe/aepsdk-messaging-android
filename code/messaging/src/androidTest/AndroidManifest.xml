<!--
  Disable Firebase auto-initialization in the instrumentation test APK.

  The messaging module declares firebase-messaging as compileOnly / androidTestImplementation
  but does NOT apply the google-services Gradle plugin, so the string resources that Firebase
  needs (google_app_id, etc.) are never generated. Without this override the androidx.startup
  InitializationProvider tries to initialize Firebase on process start and crashes with
  Resources$NotFoundException before any test can run.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application>
        <!-- Remove the Firebase/androidx.startup auto-init provider from the test APK. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="remove" />
    </application>

</manifest>
